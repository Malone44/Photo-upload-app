# Kopiér denne fil til .env og udfyld med dine egne værdier.
# .env må ALDRIG committes til Git.

PORT=3000
PASSWORD=skift-mig
PASSWORD_ALT=
EVENT_NAME=Mit arrangement

SSL_CERT=/etc/letsencrypt/live/dit-domæne.dk/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/dit-domæne.dk/privkey.pem

PUBLIC_URL=https://dit-domæne.dk:8443
